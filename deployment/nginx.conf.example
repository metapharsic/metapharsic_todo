server {
    listen 80;
    server_name yourdomain.com; # Replace with your domain or IP

    # Frontend - Serve static files from the build folder
    location / {
        root /var/www/metapharsic-todo/metapharsic-frontend/dist;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Backend - Proxy API requests to the Node.js server
    location /api {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Security: Deny access to .env files
    location ~ /\.env {
        deny all;
    }

    # Optional: Gzip compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
}
